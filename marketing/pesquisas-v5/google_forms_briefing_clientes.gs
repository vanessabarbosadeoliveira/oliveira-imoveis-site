// =============================================================================
// FUNÇÃO COMBO · CRIA OS DOIS DE UMA VEZ
// =============================================================================
function criarOsDois() {
  Logger.log('Criando os 2 formulários...');
  criarFormularioAcupuntura();
  criarFormularioLojaRoupa();
  Logger.log('Os 2 formulários estão prontos no seu Google Drive.');
  Logger.log('Os links de cada um foram impressos acima.');
}
