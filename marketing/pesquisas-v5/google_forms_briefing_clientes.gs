/**
 * Oliveira Imóveis · Análise de Mercado V5
 * Cria automaticamente 2 Google Forms (acupuntura + loja de roupa) com a
 * LOGO DA OLIVEIRA IMÓVEIS embutida.
 *
 * COMO USAR:
 * 1. Acesse https://script.google.com
 * 2. Clique em "Novo projeto"
 * 3. Apague o código padrão e cole TODO este arquivo (inclui logo em base64)
 * 4. Clique no botão "Executar" (Play ▶) — escolha qual função rodar:
 *    - criarFormularioAcupuntura()  → form para clínica de acupuntura
 *    - criarFormularioLojaRoupa()   → form para loja de roupa
 *    - criarOsDois()                → cria os dois de uma vez
 * 5. Na primeira execução o Google vai pedir permissão. Aceite.
 * 6. Veja o log (Ver > Logs ou Cmd+Enter) para pegar o LINK do formulário criado.
 * 7. Compartilhe o link com a cliente via WhatsApp ou e-mail.
 *
 * As respostas aparecem na aba "Respostas" do form e também num Google Sheet
 * que é criado automaticamente.
 */

// =============================================================================
// LOGO OLIVEIRA · base64 embutida (300x200px otimizada · ~65KB)
// =============================================================================
const LOGO_BASE64 = '';

function getLogoBlob() {
  return Utilities.newBlob(
    Utilities.base64Decode(LOGO_BASE64),
    'image/png',
    'logo-oliveira.png'
  );
}

// =============================================================================
// FUNÇÃO 1 · FORM PARA CLIENTE DE ACUPUNTURA
// =============================================================================
function criarFormularioAcupuntura() {
  var form = FormApp.create('Análise de Mercado · Portofino Buritis · Clínica de Acupuntura');

  form.setDescription(
    'Oliveira Imóveis · Inteligência Comercial\n\n' +
    'Esta análise vai te ajudar a decidir COM SEGURANÇA se vale abrir sua clínica ' +
    'de acupuntura no Portofino, em Buritis (BH). Vamos verificar concorrentes diretos, ' +
    'demanda real do bairro e projetar break-even em meses.\n\n' +
    'São 10 perguntas (7 críticas + 3 opcionais). Em até 24h depois das suas respostas ' +
    'você recebe: relatório PDF com veredito, lista de concorrentes diretos no raio 1,5km, ' +
    'projeção de break-even e recomendação de posicionamento.\n\n' +
    'Curadoria inteligente de pontos comerciais — Oliveira Imóveis'
  );

  // LOGO no topo do formulário
  form.addImageItem()
    .setTitle('Oliveira Imóveis')
    .setHelpText('Curadoria Inteligente de Pontos Comerciais')
    .setImage(getLogoBlob())
    .setAlignment(FormApp.Alignment.CENTER)
    .setWidth(280);

  // ===== SOBRE A CLIENTE =====
  form.addSectionHeaderItem()
    .setTitle('Sobre você e sua operação atual')
    .setHelpText('4 perguntas rápidas sobre seu histórico profissional.');

  form.addTextItem()
    .setTitle('1. De onde você está vindo?')
    .setHelpText('Cidade + bairro de origem (ex: "Goiânia / Setor Bueno" ou "BH / Belvedere")')
    .setRequired(true);

  form.addMultipleChoiceItem()
    .setTitle('2. Quanto tempo você opera com acupuntura?')
    .setChoiceValues(['Menos de 1 ano', '1 a 3 anos', '3 a 5 anos', '5 a 10 anos', 'Mais de 10 anos'])
    .setRequired(true);

  form.addTextItem()
    .setTitle('3. Qual seu ticket médio atual por consulta? (R$)')
    .setHelpText('Valor que você cobra hoje por sessão particular')
    .setRequired(true);

  form.addCheckboxItem()
    .setTitle('4. Qual é o seu diferencial principal?')
    .setHelpText('Pode marcar mais de um. Esta resposta é a MAIS IMPORTANTE — define se há gap real ou competição no Buritis.')
    .setChoiceValues([
      'Acupuntura estética / facial',
      'Dor crônica / ortopédica',
      'Medicina chinesa tradicional (MTC)',
      'Fisioterapia integrada',
      'Acupuntura para gestantes / fertilidade',
      'Acupuntura para emagrecimento',
      'Tratamento de enxaqueca / dor de cabeça',
      'Outro (descrevo abaixo)'
    ])
    .setRequired(true);

  form.addTextItem()
    .setTitle('4b. Se marcou "Outro" acima, descreva')
    .setRequired(false);

  // ===== SOBRE O ESPAÇO PORTOFINO =====
  form.addSectionHeaderItem()
    .setTitle('Sobre o espaço no Portofino')
    .setHelpText('3 perguntas para calcular o break-even matemático.');

  form.addTextItem()
    .setTitle('5. Qual a metragem da sala que o Portofino está te oferecendo? (m²)')
    .setHelpText('Acupuntura precisa de mín. 30m² para 2 macas + recepção. Ideal: 50-60m².')
    .setRequired(true);

  form.addTextItem()
    .setTitle('6. Qual o valor do aluguel pedido? (R$/mês)')
    .setHelpText('Inclua condomínio se for separado')
    .setRequired(true);

  form.addTextItem()
    .setTitle('7. Quanto você paga hoje no ponto atual? (R$/mês)')
    .setHelpText('Ou escreva "0 - atendo em casa" / "compartilho sala" se for o caso')
    .setRequired(true);

  // ===== BONUS =====
  form.addSectionHeaderItem()
    .setTitle('Bonus · ajuda muito a recomendar')
    .setHelpText('Opcional, mas se preencher a análise fica muito mais precisa.');

  form.addMultipleChoiceItem()
    .setTitle('8. Vai trazer equipe ou contratar local?')
    .setChoiceValues([
      'Vou atender sozinha(o)',
      'Trago equipe da operação atual',
      'Quero contratar profissionais locais em BH',
      'Modelo misto'
    ])
    .setRequired(false);

  form.addCheckboxItem()
    .setTitle('9. Qual modelo de pagamento você atende?')
    .setChoiceValues([
      'Particular',
      'Convênio (planos de saúde)',
      'Vouchers / cupons (Gympass, TotalPass)',
      'Outros'
    ])
    .setRequired(false);

  form.addTextItem()
    .setTitle('10. Tem perfil de Instagram com público fiel?')
    .setHelpText('Cole o link do perfil e/ou número de seguidores. Se não tiver, escreva "não tenho".')
    .setRequired(false);

  // ===== CONFIRMAÇÃO =====
  form.setConfirmationMessage(
    'Recebemos suas respostas!\n\n' +
    'Em até 24h a Vanessa vai te enviar o relatório completo da análise no WhatsApp ' +
    '— veredito (viável / não viável / com ressalvas), lista de concorrentes diretos, ' +
    'projeção de break-even e recomendação de posicionamento.\n\n' +
    'Oliveira Imóveis · Curadoria inteligente de pontos comerciais.'
  );

  form.setCollectEmail(true);
  form.setLimitOneResponsePerUser(false);

  var url = form.getPublishedUrl();
  Logger.log('========================================');
  Logger.log('FORMULÁRIO ACUPUNTURA CRIADO!');
  Logger.log('Link para enviar à cliente:');
  Logger.log(url);
  Logger.log('========================================');
  Logger.log('Link de edição (você):');
  Logger.log(form.getEditUrl());
  Logger.log('========================================');
}

